# Copy file này thành .env.local và cập nhật IP của bạn

# URL của frontend (để tạo QR code)
# Development: Dùng IP máy tính trong mạng LAN
# Production: Dùng domain thật
VITE_APP_URL=http://192.168.1.100:5173

# URL của backend API
VITE_API_URL=http://192.168.1.100:5000

# Hướng dẫn lấy IP:
# Windows: Mở CMD → chạy "ipconfig" → tìm IPv4 Address
# Mac/Linux: Mở Terminal → chạy "ifconfig | grep inet" → tìm địa chỉ 192.168.x.x
